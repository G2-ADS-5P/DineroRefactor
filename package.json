{
  "name": "school-control-monorepo",
  "private": true,
  "scripts": {
    "typecheck:academic": "npm run typecheck --prefix services/academic",
    "typecheck:attendance": "npm run typecheck --prefix services/attendance",
    "typecheck:class-offering": "npm run typecheck --prefix services/class-offering",
    "typecheck:enrollment": "npm run typecheck --prefix services/enrollment",
    "typecheck:user-auth": "npm run typecheck --prefix services/user-auth",
    "typecheck:academic-e2e": "npm run typecheck --prefix tests/academic-e2e",
    "typecheck:attendance-e2e": "npm run typecheck --prefix tests/attendance-e2e",
    "typecheck:class-offering-e2e": "npm run typecheck --prefix tests/class-offering-e2e",
    "typecheck:enrollment-e2e": "npm run typecheck --prefix tests/enrollment-e2e",
    "typecheck:user-auth-e2e": "npm run typecheck --prefix tests/user-auth-e2e",
    "typecheck:all": "npm run typecheck:academic && npm run typecheck:attendance && npm run typecheck:class-offering && npm run typecheck:enrollment && npm run typecheck:user-auth && npm run typecheck:academic-e2e && npm run typecheck:attendance-e2e && npm run typecheck:class-offering-e2e && npm run typecheck:enrollment-e2e && npm run typecheck:user-auth-e2e",
    "lint:academic": "npm run lint --prefix services/academic",
    "lint:attendance": "npm run lint --prefix services/attendance",
    "lint:class-offering": "npm run lint --prefix services/class-offering",
    "lint:enrollment": "npm run lint --prefix services/enrollment",
    "lint:user-auth": "npm run lint --prefix services/user-auth",
    "lint:all": "npm run lint:academic && npm run lint:attendance && npm run lint:class-offering && npm run lint:enrollment && npm run lint:user-auth",
    "check:academic": "npm run check --prefix services/academic",
    "check:attendance": "npm run check --prefix services/attendance",
    "check:class-offering": "npm run check --prefix services/class-offering",
    "check:enrollment": "npm run check --prefix services/enrollment",
    "check:user-auth": "npm run check --prefix services/user-auth",
    "check:all": "npm run check:academic && npm run check:attendance && npm run check:class-offering && npm run check:enrollment && npm run check:user-auth",
    "validate:all": "npm run check:all && npm run typecheck:all",
    "start:user-auth": "npm run start:dev --prefix services/user-auth",
    "start:academic": "npm run start:dev --prefix services/academic",
    "start:attendance": "npm run start:dev --prefix services/attendance",
    "start:class-offering": "npm run start:dev --prefix services/class-offering",
    "start:enrollment": "npm run start:dev --prefix services/enrollment"
  }
}
