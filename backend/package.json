{
  "name": "dinero-backend-monorepo",
  "private": true,
  "scripts": {
    "typecheck:identity": "npm run typecheck --prefix services/identity",
    "typecheck:financial": "npm run typecheck --prefix services/financial",
    "typecheck:portfolio": "npm run typecheck --prefix services/portfolio",
    "typecheck:openfinance": "npm run typecheck --prefix services/openfinance",
    "typecheck:all": "npm run typecheck:identity && npm run typecheck:financial && npm run typecheck:portfolio && npm run typecheck:openfinance",
    "lint:identity": "npm run lint --prefix services/identity",
    "lint:financial": "npm run lint --prefix services/financial",
    "lint:portfolio": "npm run lint --prefix services/portfolio",
    "lint:openfinance": "npm run lint --prefix services/openfinance",
    "lint:all": "npm run lint:identity && npm run lint:financial && npm run lint:portfolio && npm run lint:openfinance",
    "check:identity": "npm run check --prefix services/identity",
    "check:financial": "npm run check --prefix services/financial",
    "check:portfolio": "npm run check --prefix services/portfolio",
    "check:openfinance": "npm run check --prefix services/openfinance",
    "check:all": "npm run check:identity && npm run check:financial && npm run check:portfolio && npm run check:openfinance",
    "validate:all": "npm run check:all && npm run typecheck:all",
    "start:identity": "npm run start:dev --prefix services/identity",
    "start:financial": "npm run start:dev --prefix services/financial",
    "start:financial:prod": "npm run start --prefix services/financial",
    "start:portfolio": "npm run start:dev --prefix services/portfolio",
    "start:openfinance": "npm run start:dev --prefix services/openfinance",
    "test:identity": "npm test --prefix services/identity",
    "test:financial": "npm test --prefix services/financial",
    "test:portfolio": "npm test --prefix services/portfolio",
    "test:openfinance": "npm test --prefix services/openfinance"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "~4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "~11.0.2",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "~11.2.6",
    "amqplib": "~1.0.3",
    "class-transformer": "~0.5.1",
    "class-validator": "~0.15.1",
    "drizzle-orm": "~0.45.1",
    "pg": "~8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "~2.4.6",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/amqplib": "~0.10.8",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/pg": "~8.18.0",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "~0.31.9",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  }
}
